#: src/Process/Upgrade/Replay.php:64
#, php-format
msgid "Grow up from version %s successfully replayed."
msgstr "Μεγαλώστε από την έκδοση %s που επαναλαμβάνεται με επιτυχία."

#: src/Process/Upgrade/Replay.php:82
msgid "Replay update actions"
msgstr "Ενέργειες ενημέρωσης επανάληψης"

#: src/Process/Upgrade/Replay.php:100
msgid "Replay grow up action from version:"
msgstr "Επαναλάβετε τη δράση του μεγάλου από την έκδοση:"

#: src/Process/Upgrade/Replay.php:108
msgid "Replay version lower than the last one can break your installation, do it at your own risk."
msgstr "Η αναπαραγωγή έκδοσης χαμηλότερης από την τελευταία μπορεί να καταστρέψει την εγκατάστασή σας, κάντε το με δική σας ευθύνη."

#: src/Process/Upgrade/Upgrade.php:267
#, php-format
msgid "Dotclear %s is available."
msgstr "Dotclear %s είναι διαθέσιμο."

#: src/Process/Upgrade/Upgrade.php:287
msgid "To upgrade your Dotclear installation simply click on the following button. A backup file of your current installation will be created in your root directory."
msgstr "Για να αναβαθμίσετε την εγκατάσταση Dotclear απλά κάντε κλικ στο παρακάτω κουμπί. Ένα αρχείο αντιγράφου ασφαλείας της τρέχουσας εγκατάστασής σας θα δημιουργηθεί στον ριζικό σας κατάλογο."

#: src/Process/Upgrade/Upgrade.php:296
msgid "This update may potentially require some precautions, you should carefully read the information post associated with this release (see above)."
msgstr "Αυτή η ενημερωμένη έκδοση πιθανόν να απαιτεί ορισμένες προφυλάξεις, θα πρέπει να διαβάσετε προσεκτικά τις πληροφορίες που σχετίζονται με αυτήν την έκδοση (βλ. παραπάνω)."

