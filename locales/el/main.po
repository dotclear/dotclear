msgid "The installed PHP version is %1$s, the next version of Dotclear requires %2$s or higher."
msgstr "Η εγκατεστημένη έκδοση του PHP είναι %1$s, ενώ η επόμενη έκδοση του Dotclear απαιτεί %2$s ή νεότερη έκδοση."

#: src/Process/Upgrade/Home.php:79
#, php-format
msgid "Backup directory \"%s\" does not exist or is not writable."
msgstr "Ο εφεδρικός κατάλογος \"%s\" δεν υπάρχει ή δεν είναι εγγράψιμος."

#: src/Process/Upgrade/Home.php:83
msgid "Your are using Sqlite database driver, Database structure upgrade will NOT be performed."
msgstr "Χρησιμοποιείτε το πρόγραμμα οδήγησης βάσης δεδομένων Sqlite, ΔΕΝ θα πραγματοποιηθεί αναβάθμιση της δομής της βάσης δεδομένων."

#: src/Process/Upgrade/Home.php:87
msgid "Your are using developement release, some features are not available."
msgstr "Χρησιμοποιείτε την έκδοση ανάπτυξης, ορισμένα χαρακτηριστικά δεν είναι διαθέσιμα."

#: src/Process/Upgrade/Home.php:91
#, php-format
msgid "Dotclear digests file \"%s\" is not readable."
msgstr "Το αρχείο Dotclear digests \"%s\" δεν είναι αναγνώσιμο."

#: src/Process/Upgrade/Home.php:95 src/Process/Upgrade/Plugins.php:151
msgid "Official plugins repository could not be updated as there is no URL set in configuration."
msgstr "Το επίσημο αποθετήριο πρόσθετων δεν ήταν δυνατό να ενημερωθεί, καθώς δεν υπάρχει διεύθυνση URL στη ρύθμιση παραμέτρων."

#: src/Process/Upgrade/Home.php:100
msgid "Do you read the official post about this release on Dotclear's blog?"
msgstr "Έχετε διαβάσει την επίσημη ανάρτηση σχετικά με αυτή την κυκλοφορία στο blog της Dotclear;"

#: src/Process/Upgrade/Home.php:101
msgid "Does your system support this release requirements like PHP version?"
msgstr "Υποστηρίζει το σύστημά σας τις απαιτήσεις αυτής της έκδοσης, όπως η έκδοση PHP;"

#: src/Process/Upgrade/Home.php:102
msgid "Does your plugins and themes are up to date?"
msgstr "Τα plugins και τα θέματά σας είναι ενημερωμένα;"

#: src/Process/Upgrade/Home.php:103
msgid "Note if some plugins crash your installation, go back here to disable or to remove or to update them."
msgstr "Σημειώστε ότι αν κάποια πρόσθετα καταστρέψουν την εγκατάστασή σας, επιστρέψτε εδώ για να τα απενεργοποιήσετε ή να τα αφαιρέσετε ή να τα ενημερώσετε."

#: src/Process/Upgrade/Home.php:104
msgid "Once update done, do not forget to check and update blogs themes."
msgstr "Μόλις γίνει η ενημέρωση, μην ξεχάσετε να ελέγξετε και να ενημερώσετε τα θέματα των ιστολογίων."

#: src/Process/Upgrade/Home.php:167
msgid "Before performing update you should take into account some informations listed bellow:"
msgstr "Πριν εκτελέσετε την ενημέρωση θα πρέπει να λάβετε υπόψη σας ορισμένες πληροφορίες που παρατίθενται παρακάτω:"

#: src/Process/Upgrade/Langs.php:374
msgid "Install or upgrade languages from available languages"
msgstr "Εγκατάσταση ή αναβάθμιση γλωσσών από τις διαθέσιμες γλώσσες"

#: src/Process/Upgrade/Langs.php:417
